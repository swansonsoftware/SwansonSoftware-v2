<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ---------------------------------------------------------
  # 1. Redirect www to non-www
  # ---------------------------------------------------------
  RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # ---------------------------------------------------------
  # 2. Force trailing slashes for clean URLs
  #    Fixes /blog → /blog/ so React route loads correctly
  # ---------------------------------------------------------
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+[^/])$ https://swansonsoftware.com/$1/ [R=301,L]

  # ---------------------------------------------------------
  # 3. Allow real files and directories to be served normally
  # ---------------------------------------------------------
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # ---------------------------------------------------------
  # 4. SPA routing fallback
  #    Everything else goes to index.html
  # ---------------------------------------------------------
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]

</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(webp|svg)$">
    Header set Cache-Control "max-age=7776000, public"
  </FilesMatch>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "max-age=7776000, private"
  </FilesMatch>
</IfModule>

# Redirects

# Redirect 301 /index.html https://swansonsoftware.com/

Redirect 301 /index.php https://swansonsoftware.com/
Redirect 301 /default.asp https://swansonsoftware.com/
Redirect 301 /emailForm.php https://swansonsoftware.com/contact/
Redirect 301 /IntroProcess.asp https://swansonsoftware.com/
Redirect 301 /life-cycle-models.html https://swansonsoftware.com/principles/lifecycle
